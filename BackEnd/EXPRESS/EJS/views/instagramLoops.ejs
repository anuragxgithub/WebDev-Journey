<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram Profile Page</title>
</head>
<body>
    <h1>This page belongs to @<%= username %></h1>
    <button>Follow</button>
    <button>Message</button>
    <h2>Accounts that follow you : </h2>
    <% for(name of names) { %>
        <li> <%= name %> </li>
    <% } %>
</body>
</html>