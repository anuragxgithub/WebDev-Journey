<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conditionals in EJS</title>
</head>
<body>
    <h1>The value of dice after roll is : <%= diceVal %></h1>
    <% if(diceVal === 6) { %>
        <h1>Nice! Roll the dice again!</h1>
    <% } %>
</body>
</html>